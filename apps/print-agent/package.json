    "start": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "tsx": "^4.15.6",
    "typescript": "^5.5.2"
  }
}
