{
  "name": "print-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Agente local que recibe trabajos de impresión desde la API cloud y los envía a la impresora térmica USB",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@point-of-sale/receipt-printer-encoder": "^3.0.3",
    "dotenv": "^16.4.5",
    "node-hid": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/node-hid": "^1.3.4",
    "tsx": "^4.15.6",
    "typescript": "^5.5.2"
  }
}
